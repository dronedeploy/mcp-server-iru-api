# Kandji API Configuration
# Note: Kandji rebranded as "Iru" in 2025. Use your Iru tenant credentials.
# API endpoints continue to use kandji.io domains (unchanged).
KANDJI_API_TOKEN=your_api_token_here
KANDJI_SUBDOMAIN=your_subdomain_here
KANDJI_REGION=us

# Optional: Cache TTL in seconds
CACHE_TTL_DEVICES=300
CACHE_TTL_COMPLIANCE=120
CACHE_TTL_BLUEPRINTS=1800

# Optional: Enable PII redaction (true/false). When true, masks enrollment_code in blueprint payloads.
ENABLE_PII_REDACTION=false

# Optional: Set to "true" to omit the execute_device_action MCP tool (lock/restart/shutdown/erase).
MCP_DISABLE_EXECUTE_DEVICE_ACTION=false

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
