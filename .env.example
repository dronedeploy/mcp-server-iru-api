# Kandji / Iru API — optional repo copy (gitignored if you name it .env)
#
# Preferred for this workspace: put the same variables in:
#   ~/dev/.secrets/kandji.env
# (also checks ~/.secrets/kandji.env). The MCP server loads those first, then this file
# for any vars still unset. See dev/.secrets/README.md.
#
# Note: Kandji rebranded as "Iru" in 2025. API hosts remain *.kandji.io.
# Primary name used by this server:
KANDJI_API_TOKEN=your_api_token_here
# Alias: if you only set KANDJI_TOKEN in kandji.env, it is mapped to KANDJI_API_TOKEN at startup.
KANDJI_SUBDOMAIN=your_subdomain_here
KANDJI_REGION=us

# Optional: Cache TTL in seconds
CACHE_TTL_DEVICES=300
CACHE_TTL_COMPLIANCE=120
CACHE_TTL_BLUEPRINTS=1800

# Optional: Enable PII redaction (true/false). When true, masks enrollment_code in blueprint payloads.
ENABLE_PII_REDACTION=false

# Optional: Set to "true" to omit the execute_device_action MCP tool (lock/restart/shutdown/erase).
MCP_DISABLE_EXECUTE_DEVICE_ACTION=false

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=info
